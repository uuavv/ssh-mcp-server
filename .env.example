# Generate with: openssl rand -hex 32
MCP_BEARER_TOKEN=replace-with-at-least-32-random-characters
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000
MCP_PATH=/mcp
MCP_REQUESTS_PER_MINUTE=120
MCP_MAX_OUTPUT_CHARS=200000
MCP_AUDIT_LOG_PATH=/var/log/ssh-mcp/audit.jsonl

# Notion may keep Streamable HTTP sessions open. Expire idle sessions and cap
# concurrent sessions so abandoned clients cannot exhaust the server.
MCP_SESSION_TTL_SECONDS=1800
MCP_MAX_SESSIONS=32

# Trust only the local reverse proxy. Use true only when every direct client is trusted.
MCP_TRUST_PROXY=loopback
